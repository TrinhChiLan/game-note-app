<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.assignment3.fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_homeFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.assignment3.fragments.SearchFragment"
        android:label="Add Game"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.assignment3.fragments.DetailFragment"
        android:label="Game Detail"
        tools:layout="@layout/fragment_detail">
        <argument
            android:name="gameId"
            app:argType="integer" />
        <action
            android:id="@+id/action_detailFragment_to_noteEditorFragment"
            app:destination="@id/noteEditorFragment" />
        <action
            android:id="@+id/action_detailFragment_to_checklistEditorFragment"
            app:destination="@id/checklistEditorFragment" />
    </fragment>

    <fragment
        android:id="@+id/noteEditorFragment"
        android:name="com.example.assignment3.fragments.NoteEditorFragment"
        android:label="Edit Note"
        tools:layout="@layout/fragment_note_editor">
        <argument
            android:name="gameId"
            app:argType="integer" />
        <argument
            android:name="noteId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/checklistEditorFragment"
        android:name="com.example.assignment3.fragments.ChecklistEditorFragment"
        android:label="Edit Checklist"
        tools:layout="@layout/fragment_checklist_editor">
        <argument
            android:name="gameId"
            app:argType="integer" />
        <argument
            android:name="noteId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>
</navigation>